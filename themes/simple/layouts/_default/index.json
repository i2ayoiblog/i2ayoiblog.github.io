{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- $.Scratch.Add "index" (dict "title" .Title "href" .RelPermalink "description" .Params.description "tags" .Params.tags "categories" .Params.categories "content" (.Plain | truncate 200)) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
